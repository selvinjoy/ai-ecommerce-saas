# ============================================================
# AI E-Commerce SaaS - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- App ---
APP_ENV=development
SECRET_KEY=your-super-secret-key-min-32-chars
DEBUG=true

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# --- Apify (Scraping) ---
APIFY_API_TOKEN=apify_api_...

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-04

# --- Meta Marketing API ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_PAGE_ID=

# --- TikTok Marketing API ---
TIKTOK_APP_ID=
TIKTOK_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# --- Zendrop ---
ZENDROP_API_KEY=
ZENDROP_BASE_URL=https://app.zendrop.com/api

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_ecommerce
DATABASE_URL_DEV=sqlite:///./dev.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Supabase Auth ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# --- Stop-Loss Defaults ---
STOP_LOSS_SPEND_AUD=200.0
STOP_LOSS_MIN_ROAS=1.5
STOP_LOSS_MAX_CPC_AUD=2.50

# --- Target Market ---
DEFAULT_TARGET_MARKET=AU
GST_RATE=0.10
